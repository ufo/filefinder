@ECHO OFF

IF NOT "%VS120COMNTOOLS%" == "" GOTO VS2013
IF NOT "%VS140COMNTOOLS%" == "" GOTO VS2015

ECHO No build environment found!
EXIT 1

:VS2013
SET BUILDER=VS2013
CALL "%VS120COMNTOOLS%..\..\VC\vcvarsall.bat" x86
GOTO FINISH

:VS2015
SET BUILDER=VS2015
CALL "%VS140COMNTOOLS%..\..\VC\vcvarsall.bat" x64
GOTO FINISH

:FINISH
SET SETUP_ENV_DONE=1
